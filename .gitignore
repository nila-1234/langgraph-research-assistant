.venv/
*.venv/
venv/
env/
ENV/

# Vector databases
chroma_db/
*.sqlite3

# macOS
.DS_Store
**/.DS_Store

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/
